*.pyc
__pycache__/
*.log
/.venv/
backend/venv/
backend/.venv/
frontend/node_modules/

# Editor/agent artifacts
.codex

# Local exports / one-off artifacts
rev.json
sev.json

# Paper build outputs (keep sources elsewhere as needed)
paper/*.aux
paper/*.out
paper/*.log

# Generated backend outputs
backend/out.txt
backend/test_out*.txt
backend/test.pdf

# Runtime datasets (required layout: backend/data/{training,testing}/{raw,processed})
# Testing datasets are generated locally.
backend/data/testing/raw/*
backend/data/testing/processed/*
!backend/data/testing/raw/*.csv
!backend/data/testing/processed/*.csv
!backend/data/testing/raw/*.json
!backend/data/testing/processed/*.json

# Training datasets (raw + processed)
backend/data/training/processed/*
backend/data/training/raw/*
!backend/data/training/raw/*.csv
!backend/data/training/processed/*.csv
!backend/data/training/raw/*.json
!backend/data/training/processed/*.json

# Keep directory skeletons tracked (must be after the training/raw ignore rule)
!backend/data/**/.gitkeep
!backend/data/training/raw/.gitkeep
!backend/data/training/processed/.gitkeep

# Model artifacts
# Track joblib artifacts so the app works out-of-the-box.
backend/models/*.pkl
backend/models/*.bin
backend/models/*.onnx
!backend/models/.gitkeep
